# ─── Dev image: tsx watch with hot reload ────────────────────────────────────
FROM node:20-alpine

WORKDIR /app

# Install all dependencies (including devDependencies)
COPY package.json package-lock.json* ./
RUN npm ci

# Source code and config are volume-mounted, but copy for fallback
COPY tsconfig.json ./
COPY config/ ./config/

# Create data directory
RUN mkdir -p data/whatsapp-auth

EXPOSE 3000

CMD ["npx", "tsx", "watch", "src/main.ts"]
