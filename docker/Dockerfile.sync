# в”Ђв”Ђв”Ђ Obsidian Headless Sync в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Runs `ob sync --continuous` to keep the vault in sync with Obsidian Cloud.
# Auto-login via env vars (OBSIDIAN_EMAIL, OBSIDIAN_PASSWORD, OBSIDIAN_VAULT_NAME)
# or uses pre-existing credentials from obsidian-auth volume.

FROM node:22-alpine

RUN npm install -g obsidian-headless

WORKDIR /vault

COPY docker/sync-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

HEALTHCHECK --interval=60s --timeout=5s --start-period=30s --retries=3 \
  CMD pgrep -f "ob sync" || exit 1

ENTRYPOINT ["/entrypoint.sh"]
