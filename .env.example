# DBot Environment Variables

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=your-mistral-api-key

# API Authentication
DBOT_API_KEY=your-api-key-here

# Override config values (pattern: DBOT__{SECTION}__{KEY})
# DBOT__LLM__DEFAULT_PROVIDER=anthropic
# DBOT__SERVER__PORT=3000
# DBOT__MESSAGE_BUS__TYPE=redis

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Obsidian Vault
DBOT_VAULT_PATH=./data/vault
DBOT_VAULT_SYNC_ENABLED=false
DBOT_VAULT_DEFAULT_FOLDER=/

# Obsidian Sync (for obsidian-sync container auto-login)
OBSIDIAN_EMAIL=your-obsidian-email
OBSIDIAN_PASSWORD=your-obsidian-password
OBSIDIAN_VAULT_NAME=your-vault-name
OBSIDIAN_VAULT_PASSWORD=your-vault-encryption-password

# Node environment
NODE_ENV=development
